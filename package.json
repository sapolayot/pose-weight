{
  "name": "pose-weight",
  "version": "1.0.0",
  "description": "pose-weight",
  "main": "src/server.ts",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rm -rf dist && tsc && node ./src/scripts/copy-fontawesome.mjs && node ./src/scripts/transpile-public-js.mjs && cp -R src/public dist/public",
    "compat:public-js": "node ./src/scripts/transpile-public-js.mjs",
    "compat:icons": "node ./src/scripts/copy-fontawesome.mjs",
    "start": "node dist/server.js",
    "postinstall": "node ./src/scripts/copy-fontawesome.mjs"
  },
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-session": "1.19.0",
    "mysql2": "3.22.5",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "6.4.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/node": "26.1.0",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "3.1.14",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "tsx": "4.22.5",
    "esbuild": "0.25.10",
    "typescript": "6.0.3"
  }
}
